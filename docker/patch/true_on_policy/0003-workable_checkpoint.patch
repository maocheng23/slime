+def robust_scramble(s: int, p: int):
+    # 1. 强制转为 64 位，防止 Python 无限精度干扰
+    MASK = 0xFFFFFFFFFFFFFFFF
+    
+    # 2. 更好的组合方式：不要简单的位移，使用更复杂的质数乘法
+    # 这里的质数选取参考了 SplitMix64 算法
+    x = (s ^ p) & MASK
+    x = (x + 0x9e3779b97f4a7c15) & MASK
+    
+    # 3. 两次混淆（Avalanche Step）
+    x = ((x ^ (x >> 30)) * 0xbf58476d1ce4e5b9) & MASK
+    x = ((x ^ (x >> 27)) * 0x94d049bb133111eb) & MASK
+    x = x ^ (x >> 31)
+    
+    return x & MASK
+
+def multinomial_with_seed(inputs, seed, positions):
+    results = []
+    # 优化点：避免在循环内反复创建设备上的 Generator，提升性能
+    device = inputs.device
+    g = torch.Generator(device=device) 
+    
+    for i in range(inputs.shape[0]):
+        s_val = int(seed[i].item())
+        p_val = int(positions[i].item())
+        
+        # 使用强混淆种子
+        final_seed = robust_scramble(s_val, p_val)
+        g.manual_seed(final_seed)
+        
+        idx = torch.multinomial(inputs[i:i+1], 1, generator=g)
+        results.append(idx)
+        
+    return torch.cat(results, dim=0)
